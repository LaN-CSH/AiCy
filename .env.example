# AiCy 백엔드 환경설정 예시 — 복사해서 .env 로 저장하고 값을 채우세요.
# (.env 는 커밋하지 마세요.)

# --- 두뇌 (LLM) ---
OPENAI_KEY=sk-...
AICY_LLM_MODEL=gpt-4o

# --- 음성 (TTS) ---
# chatterbox : 로컬 뉴럴(GPU, MIT). 품질↑·클로닝·감정조절. .venv311 파이썬으로 실행 필요
# edge   : MS Edge 뉴럴 음성(클라우드, 무료·키 불필요). 빠름 — 권장 placeholder
# sapi   : Windows 로컬 음성(System.Speech). 오프라인·GPU 불필요·키 불필요 (ffmpeg 필요)
# gtts   : Google TTS(클라우드, 키 불필요)
# elevenlabs : 클라우드 고품질(키 필요)
AICY_TTS_BACKEND=edge
# (edge) 빈값이면 LANG으로 자동: ko=ko-KR-SunHiNeural, en=en-US-AriaNeural
AICY_EDGE_VOICE=
# 문장 분할 파이프라이닝: auto(기본) = 느린 백엔드(chatterbox)일 때만 켜짐 | 1 | 0
# 답변을 문장별로 생성·전송해 체감 지연을 '첫 문장 생성 시간'으로 단축
AICY_TTS_SPLIT=auto
# (chatterbox) 감정 과장 0~1 / CFG / 참조 음성 경로(넣으면 그 목소리로 클로닝)
# 여성 목소리 예시: assets/aicy-voice-ref.wav (임시 placeholder — 추후 정식 보이스로 교체)
AICY_CB_EXAGGERATION=0.5
AICY_CB_CFG=0.5
AICY_CB_REF_AUDIO=assets/aicy-voice-ref.wav
# (sapi) 빈값이면 LANG으로 자동: ko=Microsoft Heami, en=Microsoft Zira
AICY_SAPI_VOICE=
# (sapi) ffmpeg 경로. 빈값이면 PATH 및 C:/ffmpeg 자동 탐색
AICY_FFMPEG=
# (sapi) 목소리 피치 배율. 1.0=원음, 1.15~1.35=어리고 높은 톤(길이는 유지됨)
AICY_VOICE_PITCH=1.0
# (elevenlabs 쓸 때만)
ELEVENLABS=
AICY_VOICE_ID=edaoIXGiOsk7Opf9lAsF
AICY_TTS_MODEL=eleven_multilingual_v2

# --- 언어 / 서버 ---
AICY_LANG=ko
AICY_WS_HOST=localhost
AICY_WS_PORT=8765
